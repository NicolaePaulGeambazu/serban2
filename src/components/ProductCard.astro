---
import Icon from './Icon.astro';
import Seal from './Seal.astro';
import AffiliateButton from './AffiliateButton.astro';
import type { CollectionEntry } from 'astro:content';

type Product = CollectionEntry<'categories'>['data']['products'][number];
interface Props { product: Product; }
const { product: p } = Astro.props;
---
<article
  class:list={['prod-card', p.win && 'win']}
  id={p.id}
  data-rank={p.rank}
  data-feat={p.features.join(' ')}
>
  <div class="pc-media">
    <div class="pc-rank">{p.rank}</div>
    {p.win && <Seal id={p.id} class="pc-seal" />}
    {p.image
      ? <img class="pc-shot" src={p.image} alt={p.name} width="180" height="168" loading="lazy" decoding="async" />
      : <div class="pc-shot"><Icon name="circle" /></div>}
  </div>

  <div class="pc-body">
    <span class="pc-tag">{p.tag}</span>
    <h3 class="pc-name">{p.name}</h3>
    {p.specs.length > 0 && (
      <div class="pc-chips">
        {p.specs.map((s) => <span>{s.label ? `${s.value} ${s.label}` : s.value}</span>)}
      </div>
    )}
  </div>

  <div class="pc-buy">
    <AffiliateButton url={p.affiliateUrl || p.emagUrl} class="btn btn-primary" aria={`Vezi ${p.name} pe eMAG`} />
    <span class="ver"><span class="dot"></span>Prețul curent îl vezi pe eMAG</span>
  </div>
</article>
