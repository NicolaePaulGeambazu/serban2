---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import QuickPicks from '../../components/QuickPicks.astro';
import ProductCard from '../../components/ProductCard.astro';
import AffiliateButton from '../../components/AffiliateButton.astro';
import Icon from '../../components/Icon.astro';
import Jsonld from '../../components/Jsonld.astro';
import { site } from '../../data/site';
import { deeplink, AFFILIATE_REL } from '../../data/affiliate';

export async function getStaticPaths() {
  const cats = await getCollection('categories');
  return cats.map((c) => ({ params: { slug: c.id }, props: { cat: c } }));
}

const { cat } = Astro.props;
const d = cat.data;
const fmt = (n: number) => n.toLocaleString('ro-RO');
const winner = d.products.find((p) => p.win) ?? d.products[0];
const updated = new Date(d.updated).toLocaleDateString('ro-RO', { day: 'numeric', month: 'long', year: 'numeric' });

const itemList = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: d.h1,
  itemListElement: d.products.map((p) => ({
    '@type': 'ListItem',
    position: p.rank,
    item: {
      '@type': 'Product',
      name: p.name,
      ...(p.image ? { image: p.image } : {}),
      url: deeplink(p.affiliateUrl || p.emagUrl),
      review: {
        '@type': 'Review',
        reviewRating: { '@type': 'Rating', ratingValue: p.score, bestRating: 10, worstRating: 1 },
        author: { '@type': 'Organization', name: `Redacția ${site.name}` },
      },
    },
  })),
};
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: d.faq.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---
<Base title={d.title} description={d.intro} current="/categorii/" bodyClass="has-mcta">
  <div class="wrap">
    <Breadcrumb items={[{ label: 'Acasă', href: '/' }, { label: d.parent, href: '/categorii/' }, { label: d.h1 }]} />
    <section class="cat-hero">
      <span class="eyebrow">Clasament · actualizat {updated}</span>
      <h1>{d.h1}</h1>
      <p class="lede">{d.intro}</p>
      <div class="meta-row">
        <span class="m fresh"><Icon name="clock" /> Actualizat <b>{updated}</b></span>
        <span class="m"><b>{d.productsCount}</b> modele comparate</span>
        {d.reviewsRead > 0 && <span class="m"><b>{fmt(d.reviewsRead)}</b> recenzii citite</span>}
        <span class="author"><span class="av">VR</span> Verificat de redacția {site.name}</span>
      </div>
    </section>

    <QuickPicks picks={d.quickPicks} products={d.products} />
  </div>

  <div class="toolbar" id="clasament">
    <div class="wrap tb-row">
      <span class="count" id="count">{d.products.length} modele</span>
      <div class="chips" role="group" aria-label="Filtre funcții">
        {d.featureFilters.map((f) => (
          <button class="chip" data-feat={f.key} aria-pressed="false">{f.label}</button>
        ))}
      </div>
    </div>
  </div>

  <div class="wrap">
    <div class="rank-list" id="rankList">
      {d.products.map((p) => <ProductCard product={p} />)}
      <p class="empty" id="empty">Niciun model nu se potrivește cu filtrele alese. <button class="ck-link" id="clearF" style="color:var(--emerald)">Resetează filtrele</button></p>
    </div>
  </div>

  <!-- METHOD -->
  <section class="method">
    <div class="wrap">
      <span class="eyebrow">Cum lucrăm</span>
      <h2 style="margin-top:10px">Cum am ales produsele din acest clasament</h2>
      <div class="steps">
        <div class="step"><div class="no">01</div><h3>Pornim de la ce contează</h3><p>Produsele populare din categorie, cu specificațiile oficiale și recenziile publice de pe eMAG.</p></div>
        <div class="step"><div class="no">02</div><h3>Comparăm pe fapte</h3><p>Caracteristicile relevante și ce spun cumpărătorii. Fără note inventate sau teste de laborator.</p></div>
        <div class="step"><div class="no">03</div><h3>Recomandăm pe buget</h3><p>Ordonăm după cea mai bună alegere pentru fiecare gamă de preț.</p></div>
        <div class="step"><div class="no">04</div><h3>Actualizăm</h3><p>Modelele și prețurile se schimbă des — revizuim periodic. Prețul exact e pe eMAG.</p></div>
      </div>
      <div class="disclosure">
        <Icon name="info" />
        <span><b style="color:#fff">Transparență afiliat.</b> Când cumperi printr-un link de pe {site.name} primim un comision de la eMAG. Nu te costă nimic în plus și nu influențează ordinea din clasament — <a href="/legal/afiliere/" style="color:#fff;text-decoration:underline">detalii aici</a>.</span>
      </div>
    </div>
  </section>

  <!-- GUIDE -->
  {d.guide.length > 0 && (
    <section class="article" id="ghid">
      <div class="wrap prose">
        <span class="eyebrow">Ghid de cumpărare</span>
        <h2>Ce contează când alegi</h2>
        {d.guide.map((g) => (
          <>
            <h3>{g.h3}</h3>
            <p>{g.body}</p>
            {g.callout && <div class="callout"><b>Pe scurt:</b> {g.callout}</div>}
          </>
        ))}
      </div>
    </section>
  )}

  <!-- FAQ -->
  {d.faq.length > 0 && (
    <section style="padding-top:0">
      <div class="wrap prose">
        <span class="eyebrow">Întrebări frecvente</span>
        <h2 style="margin-top:10px;margin-bottom:6px">Ce ne întreabă cititorii</h2>
        {d.faq.map((f) => (
          <details class="q">
            <summary>{f.q}<span class="ic"><Icon name="plus" /></span></summary>
            <div class="a">{f.a}</div>
          </details>
        ))}
      </div>
    </section>
  )}

  <!-- CONCLUSION -->
  <section style="padding-top:0">
    <div class="wrap">
      <div class="concluzie">
        <span class="eyebrow">Concluzie</span>
        <h2>Care e verdictul?</h2>
        <p>{d.conclusion}</p>
        <div class="pick">
          <div><b>{winner.name}</b><span>câștigătorul clasamentului</span></div>
          <AffiliateButton url={winner.affiliateUrl || winner.emagUrl} label="Vezi pe eMAG" class="btn btn-gold" icon={false} aria={`Vezi ${winner.name} pe eMAG`} />
        </div>
      </div>
    </div>
  </section>

  <!-- sticky mobile CTA -->
  <div class="m-cta" slot="after">
    <div class="p"><b>Câștigător</b><span>{winner.name}</span></div>
    <a href={deeplink(winner.affiliateUrl || winner.emagUrl)} rel={AFFILIATE_REL} target="_blank" aria-label={`Vezi ${winner.name} pe eMAG`}>Vezi pe eMAG</a>
  </div>

  <Jsonld schema={itemList} />
  {d.faq.length > 0 && <Jsonld schema={faqSchema} />}
</Base>

<script>
  // filter + sort + quick-pick flash
  const list = document.getElementById('rankList');
  if (list) {
    const cards = Array.from(list.querySelectorAll('.prod-card')) as HTMLElement[];
    const priceChips = Array.from(document.querySelectorAll('.chip[data-price]'));
    const featChips = Array.from(document.querySelectorAll('.chip[data-feat]'));
    const sortSel = document.getElementById('sort') as HTMLSelectElement | null;
    const countEl = document.getElementById('count');
    const emptyEl = document.getElementById('empty') as HTMLElement | null;
    let priceMin: number | null = null;
    let priceMax: number | null = null;
    const feats: Record<string, boolean> = {};

    function inBucket(p: number) {
      return (priceMin === null || p >= priceMin) && (priceMax === null || p <= priceMax);
    }
    function apply() {
      let shown = 0;
      cards.forEach((c) => {
        const p = Number(c.dataset.price);
        const cf = (c.dataset.feat || '').split(' ');
        const okP = inBucket(p);
        const okF = Object.keys(feats).every((k) => !feats[k] || cf.indexOf(k) > -1);
        const show = okP && okF;
        c.style.display = show ? '' : 'none';
        if (show) shown++;
      });
      if (countEl) countEl.textContent = shown + (shown === 1 ? ' model' : ' modele');
      if (emptyEl) emptyEl.style.display = shown ? 'none' : 'block';
    }
    function sortNow() {
      const v = sortSel?.value;
      const sorted = cards.slice().sort((a, b) => {
        if (v === 'rank') return Number(a.dataset.rank) - Number(b.dataset.rank);
        if (v === 'score') return Number(b.dataset.score) - Number(a.dataset.score);
        if (v === 'asc') return Number(a.dataset.price) - Number(b.dataset.price);
        if (v === 'desc') return Number(b.dataset.price) - Number(a.dataset.price);
        return 0;
      });
      sorted.forEach((c) => list.appendChild(c));
      if (emptyEl) list.appendChild(emptyEl);
    }
    priceChips.forEach((ch) => ch.addEventListener('click', () => {
      priceChips.forEach((x) => x.setAttribute('aria-pressed', 'false'));
      ch.setAttribute('aria-pressed', 'true');
      const el = ch as HTMLElement;
      priceMin = el.dataset.min ? Number(el.dataset.min) : null;
      priceMax = el.dataset.max ? Number(el.dataset.max) : null;
      apply();
    }));
    featChips.forEach((ch) => ch.addEventListener('click', () => {
      const f = (ch as HTMLElement).dataset.feat!;
      const on = ch.getAttribute('aria-pressed') === 'true';
      ch.setAttribute('aria-pressed', on ? 'false' : 'true');
      feats[f] = !on;
      apply();
    }));
    sortSel?.addEventListener('change', sortNow);
    document.getElementById('clearF')?.addEventListener('click', () => {
      priceMin = null; priceMax = null;
      Object.keys(feats).forEach((k) => (feats[k] = false));
      priceChips.forEach((x) => x.setAttribute('aria-pressed', (x as HTMLElement).dataset.price === 'all' ? 'true' : 'false'));
      featChips.forEach((x) => x.setAttribute('aria-pressed', 'false'));
      apply();
    });

    // quick-pick highlight
    document.querySelectorAll('a[data-flash]').forEach((a) => {
      a.addEventListener('click', () => {
        const id = a.getAttribute('href');
        if (!id) return;
        setTimeout(() => {
          const el = document.querySelector(id);
          if (!el) return;
          el.classList.remove('flash');
          void (el as HTMLElement).offsetWidth;
          el.classList.add('flash');
        }, 380);
      });
    });

    // flash the target card when arriving directly via #anchor (e.g. from search)
    function flashHash() {
      const h = location.hash;
      if (!h || h.length < 2) return;
      let el: Element | null = null;
      try { el = document.querySelector(h); } catch (e) { return; }
      if (el && el.classList.contains('prod-card')) {
        el.classList.remove('flash');
        void (el as HTMLElement).offsetWidth;
        el.classList.add('flash');
      }
    }
    setTimeout(flashHash, 300);
    window.addEventListener('hashchange', flashHash);
  }

  // animate score dials
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    document.querySelectorAll('.dial').forEach((d) => {
      const el = d as HTMLElement;
      const target = parseInt(getComputedStyle(el).getPropertyValue('--val')) || 0;
      el.style.setProperty('--val', '0');
      let n = 0;
      const step = Math.max(2, Math.round(target / 28));
      const t = setInterval(() => {
        n += step;
        if (n >= target) { n = target; clearInterval(t); }
        el.style.setProperty('--val', String(n));
      }, 16);
    });
  }
</script>
