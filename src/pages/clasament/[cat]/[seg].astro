---
import { getCollection } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import ProductCard from '../../../components/ProductCard.astro';
import AffiliateButton from '../../../components/AffiliateButton.astro';
import Icon from '../../../components/Icon.astro';
import Jsonld from '../../../components/Jsonld.astro';
import Byline from '../../../components/Byline.astro';
import { site } from '../../../data/site';
import { deeplink, AFFILIATE_REL } from '../../../data/affiliate';
import { getAuthor } from '../../../data/authors';
import { CATEGORY_SEGMENTS, productMatchesSegment } from '../../../data/subcategories';

const cleanCat = (h1) => h1.replace('Cele mai bune ', '').replace('Cei mai buni ', '').replace(/ în 2026$/, '');

// Generic sub-ranking pages: /clasament/<cat>/<segment>/. One page per configured
// segment that has ≥1 product. Products are re-ranked 1..n within the segment.
export async function getStaticPaths() {
  const clean = (h1) => h1.replace('Cele mai bune ', '').replace('Cei mai buni ', '').replace(/ în 2026$/, '');
  const cats = await getCollection('categories');
  const paths = [];
  for (const [catId, cfg] of Object.entries(CATEGORY_SEGMENTS)) {
    const cat = cats.find((c) => c.id === catId);
    if (!cat) continue;
    for (const seg of cfg.segments) {
      const products = cat.data.products
        .filter((p) => productMatchesSegment(p, seg))
        .sort((a, b) => a.rank - b.rank)
        .map((p, i) => ({ ...p, rank: i + 1, win: i === 0 }));
      if (!products.length) continue;
      const others = cfg.segments
        .filter((s) => s.slug !== seg.slug && cat.data.products.some((p) => productMatchesSegment(p, s)))
        .map((s) => ({ slug: s.slug, label: s.label }));
      paths.push({
        params: { cat: catId, seg: seg.slug },
        props: {
          cat, kind: cfg.kind, navLabel: cfg.navLabel,
          segLabel: seg.label, catName: clean(cat.data.h1), products, others,
        },
      });
    }
  }
  return paths;
}

const { cat, kind, navLabel, segLabel, catName, products, others } = Astro.props;
const d = cat.data;
const winner = products[0];
const updated = new Date(d.updated).toLocaleDateString('ro-RO', { day: 'numeric', month: 'long', year: 'numeric' });

const h1 = `Cele mai bune ${catName} ${segLabel} în 2026`;
const intro = kind === 'brand'
  ? `Am ales și am comparat modelele ${segLabel} de ${catName} din topul nostru, pe baza specificațiilor, a dotărilor și a recenziilor. Mai jos ai fiecare model ${segLabel}, cu verdictul nostru și link direct.`
  : `Cauți ${catName} de ${segLabel}? Am filtrat topul nostru și am păstrat doar modelele din această categorie, ordonate pe baza specificațiilor, a dotărilor și a recenziilor. Mai jos ai fiecare model, cu verdictul nostru și link direct.`;

const itemList = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: h1,
  itemListElement: products.map((p) => ({
    '@type': 'ListItem',
    position: p.rank,
    item: {
      '@type': 'Product',
      name: p.name,
      ...(p.image ? { image: p.image } : {}),
      url: deeplink(p.affiliateUrl || p.emagUrl),
      review: {
        '@type': 'Review',
        reviewRating: { '@type': 'Rating', ratingValue: p.score, bestRating: 10, worstRating: 1 },
        author: { '@type': 'Person', name: getAuthor(d.author).name },
      },
    },
  })),
};
---
<Base title={h1} description={intro} current="/categorii/" bodyClass="has-mcta">
  <div class="wrap">
    <Breadcrumb items={[
      { label: 'Acasă', href: '/' },
      { label: d.parent, href: '/categorii/' },
      { label: d.h1, href: `/clasament/${cat.id}/` },
      { label: segLabel },
    ]} />
    <section class="cat-hero">
      <span class="eyebrow">Recenzii · {navLabel.toLowerCase()} · actualizat {updated}</span>
      <h1>{h1}</h1>
      <p class="lede">{intro}</p>
      <div class="meta-row">
        <span class="m fresh"><Icon name="clock" /> Actualizat <b>{updated}</b></span>
        <span class="m"><b>{products.length}</b> {products.length === 1 ? 'model' : 'modele'} · {segLabel}</span>
        <span class="m"><a href={`/clasament/${cat.id}/`} style="color:var(--emerald);font-weight:700">Vezi topul complet →</a></span>
      </div>
      <Byline authorId={d.author} updated={d.updated} />
    </section>
  </div>

  <div class="wrap">
    <div class="rank-list">
      {products.map((p) => <ProductCard product={p} />)}
    </div>
  </div>

  {others.length > 0 && (
    <section style="padding-top:0">
      <div class="wrap prose">
        <span class="eyebrow">{navLabel}</span>
        <h2 style="margin-top:10px;margin-bottom:10px">Vezi și celelalte variante</h2>
        <div class="chips" role="group" aria-label={navLabel}>
          {others.map((o) => <a class="chip" href={`/clasament/${cat.id}/${o.slug}/`}>{o.label}</a>)}
          <a class="chip" href={`/clasament/${cat.id}/`}>Toate</a>
        </div>
      </div>
    </section>
  )}

  <section class="method method-soft">
    <div class="wrap">
      <span class="eyebrow">Cum lucrăm</span>
      <h2 style="margin-top:10px">Cum am ales produsele din acest top</h2>
      <div class="steps">
        <div class="step"><div class="no">01</div><h3>Pornim de la ce contează</h3><p>Modelele populare {segLabel}, cu specificațiile oficiale și ce spun cumpărătorii care le-au folosit deja.</p></div>
        <div class="step"><div class="no">02</div><h3>Comparăm pe fapte</h3><p>Caracteristicile relevante și ce spun cumpărătorii. Fără note inventate sau teste de laborator.</p></div>
        <div class="step"><div class="no">03</div><h3>Recomandăm pe buget</h3><p>Ordonăm după cea mai bună alegere pentru fiecare gamă de preț.</p></div>
        <div class="step"><div class="no">04</div><h3>Actualizăm</h3><p>Modelele și prețurile se schimbă des — revizuim periodic. Prețul exact e pe eMAG.</p></div>
      </div>
      <div class="disclosure">
        <Icon name="info" />
        <span><b style="color:#fff">Transparență afiliat.</b> Când cumperi printr-un link de pe {site.name} primim un comision de la eMAG. Nu te costă nimic în plus și nu influențează ordinea din top — <a href="/legal/afiliere/" style="color:#fff;text-decoration:underline">detalii aici</a>.</span>
      </div>
    </div>
  </section>

  <section style="padding-top:0">
    <div class="wrap">
      <div class="concluzie">
        <span class="eyebrow">Concluzie</span>
        <h2>Care e cel mai bun {catName} {segLabel}?</h2>
        <p>Dintre modelele {segLabel} din topul nostru, <b>{winner.name}</b> e alegerea de bază pe baza specificațiilor și a recenziilor. Compară-l cu restul în <a href={`/clasament/${cat.id}/`}>topul complet</a>.</p>
        <div class="pick">
          <div><b>{winner.name}</b><span>cel mai bun · {segLabel}</span></div>
          <AffiliateButton url={winner.affiliateUrl || winner.emagUrl} label="Vezi pe eMAG" class="btn btn-gold" icon={false} aria={`Vezi ${winner.name} pe eMAG`} />
        </div>
      </div>
    </div>
  </section>

  <div class="m-cta" slot="after">
    <div class="p"><b>Cel mai bun · {segLabel}</b><span>{winner.name}</span></div>
    <a href={deeplink(winner.affiliateUrl || winner.emagUrl)} rel={AFFILIATE_REL} target="_blank" aria-label={`Vezi ${winner.name} pe eMAG`}>Vezi pe eMAG</a>
  </div>

  <Jsonld schema={itemList} />
</Base>
