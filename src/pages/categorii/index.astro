---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Icon from '../../components/Icon.astro';

const cats = (await getCollection('categories')).sort((a, b) => a.data.order - b.data.order);
---
<Base title="Toate categoriile" description="Cele mai bune produse pe categorii, alese și recenzate de redacția TopAlegeri." current="/categorii/">
  <div class="wrap">
    <Breadcrumb items={[{ label: 'Acasă', href: '/' }, { label: 'Categorii' }]} />
    <section class="cat-hero">
      <span class="eyebrow">Categorii</span>
      <h1>Toate categoriile</h1>
      <p class="lede">Alege o categorie și vezi cele mai bune produse, alese și comparate pe fapte.</p>
    </section>
    <section style="padding-top:20px">
      <div class="cats-win">
        {cats.map((c) => {
          const w = c.data.products.find((p) => p.win) ?? c.data.products[0];
          const catName = c.data.h1.replace('Cele mai bune ', '').replace('Cei mai buni ', '').replace(/ în 2026$/, '');
          return (
            <a class="cat-win" href={`/clasament/${c.id}/`} aria-label={`Vezi topul: ${catName}`}>
              <div class="cat-shot">
                {w?.image
                  ? <img src={w.image} alt={`Câștigător ${catName}: ${w.name}`} width="140" height="118" loading="lazy" decoding="async" />
                  : <span class="ic-fallback"><Icon name={c.data.icon} /></span>}
                <span class="cat-badge">Top {c.data.productsCount}</span>
              </div>
              <div class="cat-info">
                <h3>{catName}</h3>
                <div class="cat-win-row"><span class="cat-score">★ {w.score.toFixed(1)}</span><span class="cat-win-name">{w.name}</span></div>
                <span class="cat-cta">Vezi topul <Icon name="arrow" /></span>
              </div>
            </a>
          );
        })}
      </div>
    </section>
  </div>
</Base>
