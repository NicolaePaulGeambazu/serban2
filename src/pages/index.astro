---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Icon from '../components/Icon.astro';
import Seal from '../components/Seal.astro';
import AffiliateButton from '../components/AffiliateButton.astro';
import { site } from '../data/site';
import { segmentsWithProducts, productMatchesSegment, CATEGORY_SEGMENTS } from '../data/subcategories';

const cats = (await getCollection('categories')).sort((a, b) => a.data.order - b.data.order);
const guides = (await getCollection('guides')).sort((a, b) => a.data.order - b.data.order).slice(0, 3);
const fmt = (n: number) => n.toLocaleString('ro-RO');

const nProducts = cats.reduce((n, c) => n + c.data.products.length, 0);
const featured = cats[0];
const fp = featured.data.products.find((p) => p.win) ?? featured.data.products[0];

const cleanCat = (h1: string) =>
  h1.replace('Cele mai bune ', '').replace('Cei mai buni ', '').replace(/ în 2026$/, '');
const cap = (s: string) => (s ? s.charAt(0).toUpperCase() + s.slice(1) : s);
// One block per category. The row leads with a "Top N" general card, then either
// segment cards (brand / spec sub-rankings) or, if none are configured, the next
// top products as cards.
const catBlocks = cats.map((c) => {
  const sorted = [...c.data.products].sort((a, b) => a.rank - b.rank);
  const cfg = CATEGORY_SEGMENTS[c.id];
  const segs = segmentsWithProducts(c.id, c.data.products).map((s) => {
    const top = sorted.find((p) => productMatchesSegment(p, s));
    return { slug: s.slug, label: s.label, count: s.count, image: top?.image, group: s.group ?? cfg?.navLabel ?? '' };
  });
  return {
    id: c.id,
    name: cap(cleanCat(c.data.h1)),
    icon: c.data.icon,
    topN: Math.min(c.data.productsCount, 10),
    updated: new Date(c.data.updated).toLocaleDateString('ro-RO', { day: 'numeric', month: 'long', year: 'numeric' }),
    winner: sorted[0],
    top: sorted.slice(1, 4),
    segs,
    navLabel: cfg?.navLabel ?? '',
  };
});
---
<Base current="/">
  <!-- HERO -->
  <section class="hero">
    <div class="wrap hero-grid">
      <div>
        <span class="eyebrow">Recenzii · teste · verdicte</span>
        <h1>Nu ghici.<br />Vezi <span class="u">verdictul.</span></h1>
        <p class="lede">Analizăm specificațiile care contează cu adevărat și citim ce spun cumpărătorii, ca tu să alegi în două minute — nu în două seri.</p>
        <form class="search-big" role="search" action="/cauta/" method="get">
          <Icon name="search" />
          <input type="search" name="q" placeholder="Ce vrei să cumperi? ex. aspirator robot" aria-label="Caută un produs sau o categorie" />
          <button type="submit">Vezi verdictul</button>
        </form>
        <div class="pills" aria-label="Categorii populare">
          {cats.map((c) => <a href={`/clasament/${c.id}/`}>{c.data.parent === c.data.h1 ? c.data.h1 : c.data.h1.replace('Cele mai bune ', '').replace(/ în 2026$/, '')}</a>)}
        </div>
        <div class="trust-row">
          <div><span class="n">{nProducts}</span><span class="l">produse comparate</span></div>
          <div><span class="n">{cats.length}</span><span class="l">categorii</span></div>
          <div><span class="n">independent</span><span class="l">locurile nu se cumpără</span></div>
        </div>
      </div>

      <!-- Verdict card (signature) -->
      <div class="verdict" aria-label={`Câștigător · ${featured.data.parent}`}>
        <span class="tag">Câștigător · {featured.data.h1.replace('Cele mai bune ', '').replace(/ în 2026$/, '')}</span>
        <Seal id="home" />
        <div class="v-top">
          {fp.image
            ? <img class="v-shot" src={fp.image} alt={fp.name} width="118" height="118" loading="lazy" />
            : <div class="v-shot"><Icon name="circle" /></div>}
          <div class="v-meta">
            <div class="v-cat">{featured.data.parent} · Alegerea noastră</div>
            <h3 class="v-name">{fp.name}</h3>
          </div>
        </div>
        {fp.specs.length > 0 && (
          <ul class="v-specs">
            {fp.specs.slice(0, 4).map((s) => <li><Icon name="check" /> {s.value} {s.label}</li>)}
          </ul>
        )}
        <div class="v-buy">
          <AffiliateButton url={fp.affiliateUrl || fp.emagUrl} class="btn btn-primary" />
        </div>
        <p class="v-foot"><span class="dot"></span> Link afiliat · prețul curent îl vezi pe eMAG</p>
      </div>
    </div>
  </section>

  <!-- CATEGORIES -->
  <section id="categorii">
    <div class="wrap">
      <div class="s-head">
        <div>
          <span class="eyebrow">Pe categorii</span>
          <h2 style="margin-top:10px">Ce cauți astăzi?</h2>
          <p class="sub">Fiecare categorie are un top actualizat, cu argumente pentru fiecare loc.</p>
        </div>
        <a class="more" href="/categorii/">Toate categoriile →</a>
      </div>
      <div class="cat-blocks">
        {catBlocks.map((c) => (
          <div class="cat-block">
            <div class="cb-head">
              <div>
                <h3>{c.name}</h3>
                <span class="cb-meta">Top {c.topN} · actualizat {c.updated}</span>
              </div>
              <a class="cb-all" href={`/clasament/${c.id}/`}>Vezi toate <Icon name="arrow" /></a>
            </div>
            <div class="cb-row">
              <a class="pcard pcard-top" href={`/clasament/${c.id}/`} aria-label={`Top ${c.count} ${c.name}`}>
                <div class="pcard-shot">
                  {c.winner?.image
                    ? <img src={c.winner.image} alt={`Cele mai bune ${c.name}`} width="150" height="128" loading="lazy" decoding="async" />
                    : <span class="ic-fallback"><Icon name={c.icon} /></span>}
                  <span class="pcard-badge">Top {c.topN}</span>
                </div>
                <div class="pcard-body">
                  <span class="pcard-kicker">Clasament general</span>
                  <span class="pcard-name">Cele mai bune {c.name}</span>
                </div>
              </a>

              {c.segs.length > 0
                ? c.segs.map((s) => (
                    <a class="pcard" href={`/clasament/${c.id}/${s.slug}/`} aria-label={`${c.name} ${s.label}`}>
                      <div class="pcard-shot">
                        {s.image
                          ? <img src={s.image} alt={`${c.name} ${s.label}`} width="150" height="128" loading="lazy" decoding="async" />
                          : <span class="ic-fallback"><Icon name={c.icon} /></span>}
                      </div>
                      <div class="pcard-body">
                        <span class="pcard-kicker">{s.group}</span>
                        <span class="pcard-name">{s.label}</span>
                      </div>
                    </a>
                  ))
                : c.top.map((p) => (
                    <a class="pcard" href={`/clasament/${c.id}/#${p.id}`} aria-label={`${p.name} — locul ${p.rank}`}>
                      <div class="pcard-shot">
                        {p.image
                          ? <img src={p.image} alt={p.name} width="150" height="128" loading="lazy" decoding="async" />
                          : <span class="ic-fallback"><Icon name={c.icon} /></span>}
                        <span class="pcard-rank">{p.rank}</span>
                      </div>
                      <div class="pcard-body">
                        <span class="pcard-score">★ {p.score.toFixed(1)}</span>
                        <span class="pcard-name">{p.name}</span>
                      </div>
                    </a>
                  ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- METHOD -->
  <section class="method">
    <div class="wrap">
      <div class="s-head">
        <div>
          <span class="eyebrow">Cum lucrăm</span>
          <h2 style="margin-top:10px">Cum alegem produsele</h2>
          <p class="sub" style="color:#9DB0C6">Fără păreri plătite. Analizăm specificațiile reale, citim ce spun cumpărătorii — un produs urcă doar dacă merită, nu după cine plătește mai mult.</p>
        </div>
        <a class="more" href="/cum-testam/" style="color:var(--gold)">Cum lucrăm →</a>
      </div>
      <div class="steps">
        <div class="step"><div class="no">01</div><h3>Pornim de la ce contează</h3><p>Produsele populare din categorie, cu specificațiile oficiale și ce spun cumpărătorii care le-au folosit deja.</p></div>
        <div class="step"><div class="no">02</div><h3>Comparăm pe fapte</h3><p>Caracteristicile relevante și ce spun cumpărătorii. Fără note inventate sau teste de laborator.</p></div>
        <div class="step"><div class="no">03</div><h3>Recomandăm pe buget</h3><p>Ordonăm după cea mai bună alegere pentru fiecare gamă de preț.</p></div>
        <div class="step"><div class="no">04</div><h3>Actualizăm</h3><p>Modelele și piața se schimbă des — revizuim periodic. Prețul exact e pe eMAG.</p></div>
      </div>
      <div class="disclosure">
        <Icon name="info" />
        <span><b style="color:#fff">Transparență afiliat.</b> Când cumperi printr-un link de pe {site.name}, primim un comision de la eMAG. Nu te costă nimic în plus și nu influențează ordinea din top.</span>
      </div>
    </div>
  </section>

  <!-- GUIDES -->
  <section id="ghiduri">
    <div class="wrap">
      <div class="s-head">
        <div>
          <span class="eyebrow">Ghiduri de cumpărare</span>
          <h2 style="margin-top:10px">Înțelege înainte să cumperi</h2>
          <p class="sub">Explicăm pe înțelesul tuturor ce contează cu adevărat — fără jargon de fișă tehnică.</p>
        </div>
        <a class="more" href="/ghiduri/">Toate ghidurile →</a>
      </div>
      <div class="guides">
        {guides.map((g) => (
          <a class="guide" href={`/ghiduri/${g.id.replace(/\.md$/, '')}/`}>
            <div class="top"><span class="k">{g.data.kicker}</span></div>
            <div class="body">
              <h3>{g.data.title}</h3>
              <p>{g.data.description}</p>
              <span class="rd">Citește ghidul →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section style="padding-top:0">
    <div class="wrap">
      <div class="cta-band">
        <h2>Gata? Vezi verdictele.</h2>
        <p>Topuri actualizate, cu argumente pentru fiecare loc și prețul curent de pe eMAG.</p>
        <a href="/categorii/">Vezi toate topurile <Icon name="arrow" /></a>
      </div>
    </div>
  </section>
</Base>
