  "guide": [
    {
      "h3": "Puterea de aspirare: W, AW și Pa",
      "body": "Nu te lua doar după wați (consum) — uită-te la puterea reală de aspirare, exprimată în AW (air watts) sau Pa. Dyson comunică AW, mărcile asiatice comunică Pa. Peste ~20.000 Pa sau ~150 AW e foarte bine pentru covoare și păr de animale.",
      "callout": "Un aspirator puternic pe hârtie dar cu duză slabă curăță prost — contează și peria, nu doar cifra brută."
    },
    {
      "h3": "Autonomia și bateria",
      "body": "Autonomia reală în modul normal e ce contează, nu maximul din reclamă (măsurat în modul eco). 40–60 de minute acoperă un apartament de 2–3 camere. Bateria detașabilă e un mare plus: o schimbi și continui, sau o înlocuiești în timp fără să arunci aspiratorul."
    },
    {
      "h3": "Filtrarea (HEPA) pentru alergii",
      "body": "Un sistem de filtrare bun (HEPA, cu eficiență 99,9%+) reține praful fin și alergenii în loc să-i sufle înapoi în aer. Contează mult dacă ai alergii sau animale. Verifică să fie filtre lavabile, ca să nu cumperi consumabile des."
    },
    {
      "h3": "Modelele cu spălare (umed-uscat)",
      "body": "Aspiratoarele cu spălare (ex. Dreame, Rowenta X-Clean) aspiră și șterg podeaua în același timp, ideal pentru gresie și parchet. Curăță lichide și pete, dar sunt mai grele, cer întreținere (spălarea rolei) și nu înlocuiesc aspirarea clasică pentru covoare."
    },
    {
      "h3": "Greutate și manevrabilitate",
      "body": "Greutatea contează enorm când aspiri sus, pe draperii sau tavan, pentru că stă în mână. Sub ~2,5 kg e confortabil. Un tub flexibil sau care se îndoaie ajută la locuri joase (sub pat, sub mobilă) fără să te apleci."
    },
    {
      "h3": "Întreținere și accesorii",
      "body": "Recipientul de praf mai mare înseamnă goliri mai rare. Peria cu iluminare LED scoate la iveală praful fin pe podele închise. Verifică accesoriile incluse (perie pentru animale, duză îngustă) și cât de ușor se golește și se spală recipientul."
    }
  ],
  "faq": [
    {
      "q": "Câți Pa / câți AW îmi trebuie?",
      "a": "Pentru podele dure și praf normal, valorile medii ajung. Pentru covoare groase și păr de animale, caută putere mare (peste ~20.000 Pa sau ~150 AW). Dar contează și peria motorizată, nu doar cifra brută de aspirare."
    },
    {
      "q": "Cât ține bateria cu adevărat?",
      "a": "Autonomia din reclamă e măsurată în modul eco, cu duză simplă. În modul normal, cu perie motorizată, scade semnificativ. 40–60 de minute reale acoperă confortabil un apartament de 2–3 camere."
    },
    {
      "q": "Merită bateria detașabilă?",
      "a": "Da. Poți duce o baterie de rezervă pentru suprafețe mari și, mai important, o poți înlocui după câțiva ani fără să schimbi tot aspiratorul. Prelungește mult viața produsului."
    },
    {
      "q": "Un aspirator cu spălare înlocuiește mopul?",
      "a": "Pentru podele dure, în mare parte da — aspiră și șterge simultan, inclusiv pete și lichide. Dar e mai greu, cere spălarea rolei după folosire și nu curăță covoarele. Multe gospodării îl combină cu un aspirator clasic."
    },
    {
      "q": "Dyson chiar merită față de mărcile mai ieftine?",
      "a": "Dyson excelează la putere, filtrare și construcție. Mărci precum Rowenta, Xiaomi sau Dreame oferă însă 80–90% din experiență la un cost mult mai mic. Dacă bugetul e strâns, un model bun din gama medie e o alegere foarte rațională."
    },
    {
      "q": "Filtrarea HEPA contează?",
      "a": "Da, mai ales dacă ai alergii sau animale. Un sistem HEPA reține praful fin și alergenii în loc să-i reintroducă în aer. Alege filtre lavabile ca să eviți costuri repetate cu consumabilele."
    },
    {
      "q": "E greu de manevrat pe sus?",
      "a": "Greutatea contează cel mai mult când aspiri draperii, colțuri înalte sau tavan. Sub ~2,5 kg e confortabil. Modelele cu motor în mâner sunt mai echilibrate sus decât cele cu motor în partea de jos."
    },
    {
      "q": "Cât de des golesc și curăț?",
      "a": "Golește recipientul după fiecare folosire sau când ajunge la maxim. Spală filtrul periodic (dacă e lavabil) și verifică peria de fire încurcate. Întreținerea simplă păstrează puterea de aspirare la nivel maxim."
    }
  ],
