  "guide": [
    {
      "h3": "NVIDIA GeForce sau AMD Radeon?",
      "body": "NVIDIA domină la ray tracing și DLSS 4 (upscaling + Frame Generation), utile în jocurile noi cu grafică complexă. AMD Radeon oferă, de regulă, mai multă putere brută și VRAM la același preț, ideal dacă joci mai ales la rezoluție nativă, fără ray tracing agresiv.",
      "callout": "Pentru gaming la rezoluție nativă, un RX 9070 XT bate un RTX 5070 din aceeași plajă de preț. Pentru jocuri cu ray tracing greu (Cyberpunk 2077, Alan Wake 2), NVIDIA rămâne alegerea mai sigură."
    },
    {
      "h3": "Câtă memorie video (VRAM) ai nevoie?",
      "body": "8 GB e suficient azi pentru 1080p, dar începe să limiteze la texturi mari sau la 1440p în jocurile noi. 12 GB acoperă confortabil 1440p. 16 GB e recomandat pentru 4K sau pentru longevitate, mai ales dacă vrei să păstrezi placa 4-5 ani."
    },
    {
      "h3": "Bus de memorie și lățime de bandă",
      "body": "Un bus mai lat (256-bit față de 128-bit) înseamnă mai multă lățime de bandă, esențială la rezoluții mari și texturi 4K. Plăcile de 128-bit (RTX 5060) sunt gândite pentru 1080p/1440p; cele de 256-bit (RTX 5080, RX 9070/9070 XT) țin pasul la 4K."
    }
  ],
  "faq": [
    {
      "q": "GDDR6 vs GDDR7 — contează pentru gaming?",
      "a": "GDDR7 (folosit de seria RTX 50) oferă mai multă lățime de bandă la aceeași lățime de bus, ceea ce ajută la rezoluții mari. Diferența practică e mai mică decât cea dintre generații de GPU, dar contează marginal la 4K."
    },
    {
      "q": "Am nevoie de o sursă (PSU) mai puternică?",
      "a": "Da — plăcile din gama medie-superioară (RTX 5070, RX 9070/9070 XT, RTX 5080) au nevoie de o sursă de minimum 650-750W, de calitate, cu conectorii PCIe corespunzători. Verifică mereu recomandarea producătorului înainte de cumpărare."
    },
    {
      "q": "De unde câștigați bani dacă site-ul e gratuit?",
      "a": "Din comision de afiliere: dacă ajungi la eMAG printr-un link de la noi și cumperi, primim un mic procent. Prețul tău nu se schimbă, iar comisionul nu influențează clasamentul."
    }
  ],
