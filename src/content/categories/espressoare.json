  "guide": [
    {
      "h3": "Sistemul de lapte: carafă, LatteGO sau LatteCrema?",
      "body": "Dacă bei cappuccino sau latte, sistemul de lapte contează cel mai mult. Carafele LatteCrema (De'Longhi) și LatteGO (Philips) fac spumă automat, la o singură atingere. LatteGO se demontează în două piese și se spală imediat, iar carafele De'Longhi se pun la frigider între utilizări.",
      "callout": "Vrei cappuccino perfect fără efort? Alege un model cu spumare automată (LatteGO sau LatteCrema). Sistemele cu duză manuală cer exercițiu și timp."
    },
    {
      "h3": "Câte tipuri de băuturi îți trebuie?",
      "body": "Modelele de bază fac 4–6 băuturi (espresso, lungo, cappuccino). Cele premium ajung la 20–50+ rețete cu profile salvate pe utilizator. Dacă în casă fiecare bea altceva, un ecran tactil cu profile și băuturi multiple face diferența la comoditate."
    },
    {
      "h3": "Râșnița și presiunea contează?",
      "body": "Aproape toate au 15 bari, suficient pentru un espresso corect. Mai importantă e râșnița: cea ceramică (Philips) se tocește greu și e silențioasă, iar cea cu mai multe setări (Krups, De'Longhi) reglează fin grosimea măcinării pentru gustul dorit."
    }
  ],
  "faq": [
    {
      "q": "Cât de des trebuie detartrat un espressor automat?",
      "a": "Depinde de duritatea apei și de câte cafele faci, dar de obicei la fiecare 1–3 luni. Aparatele bune te anunță singure când e nevoie și au program automat de detartrare. Folosirea filtrului de apă rărește operațiunea."
    },
    {
      "q": "LatteGO sau carafă De'Longhi — care e mai bun?",
      "a": "LatteGO (Philips) e mai ușor de curățat: doar două piese, fără tuburi, se spală în câteva secunde. Carafele De'Longhi (LatteCrema) dau o spumă foarte densă și pot fi puse direct la frigider. Ambele fac spumă automat la o atingere."
    },
