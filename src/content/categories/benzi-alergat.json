  "guide": [
    {
      "h3": "Puterea motorului (CP) contează cel mai mult",
      "body": "Motorul e inima benzii. Pentru mers și jogging ușor, 2–2,5 CP continui ajung. Pentru alergare regulată și utilizatori mai grei, caută 3–4 CP. Atenție: 'CP maxim' din reclamă e mai mare decât 'CP continuu', care e valoarea reală de lucru.",
      "callout": "Un motor subdimensionat se supraîncălzește și cedează. Ia cu o rezervă de putere față de ce crezi că îți trebuie."
    },
    {
      "h3": "Suprafața de alergare",
      "body": "O bandă îngustă sau scurtă te face să alergi crispat. Pentru alergare confortabilă, caută o suprafață de minim ~120 cm lungime și ~40 cm lățime. Cu cât ești mai înalt și alergi mai repede, cu atât ai nevoie de mai mult spațiu."
    },
    {
      "h3": "Greutatea maximă suportată",
      "body": "Alege o bandă cu greutate maximă cu cel puțin 20 kg peste greutatea ta — marja asigură stabilitate, durabilitate și un motor care nu se chinuie. O bandă folosită aproape de limita ei se uzează rapid."
    },
    {
      "h3": "Amortizarea și zgomotul",
      "body": "Un sistem bun de amortizare protejează genunchii și articulațiile la impact — esențial dacă alergi des. Verifică și nivelul de zgomot dacă locuiești la bloc; motoarele inverter și platformele bine amortizate sunt mai silențioase."
    },
    {
      "h3": "Înclinarea: automată vs. manuală",
      "body": "Înclinarea simulează urcarea și crește intensitatea. Cea automată (reglabilă din consolă sau din aplicații) e mult mai practică și permite antrenamente variate. Cea manuală e mai ieftină, dar trebuie să cobori de pe bandă ca s-o schimbi."
    },
    {
      "h3": "Conectivitate și pliere",
      "body": "Aplicațiile (Kinomap, Zwift, FitShow) aduc trasee video și antrenamente ghidate care fac alergarea mai puțin plictisitoare. Verifică și dacă banda se pliază și are roți de transport — contează enorm pentru spațiul de acasă."
    }
  ],
  "faq": [
    {
      "q": "Ce putere de motor îmi trebuie?",
      "a": "Pentru mers și jogging ușor, 2–2,5 CP continui ajung. Pentru alergare regulată sau utilizatori mai grei, caută 3–4 CP. Uită-te la puterea continuă, nu la 'CP maxim' din reclamă, care e o cifră de vârf, nu de lucru."
    },
    {
      "q": "Cât de mare trebuie să fie suprafața de alergare?",
      "a": "Minim ~120 cm lungime și ~40 cm lățime pentru alergare confortabilă. Persoanele înalte și cele care aleargă rapid au nevoie de mai mult. O suprafață prea mică te face să alergi tensionat și crește riscul de accidentare."
    },
    {
      "q": "Ce greutate maximă să aleg?",
      "a": "Cel puțin 20 kg peste greutatea ta. Marja asigură stabilitate, protejează motorul și prelungește viața benzii. O bandă folosită la limita ei se uzează rapid și devine instabilă."
    },
    {
      "q": "Contează amortizarea?",
      "a": "Da, foarte mult dacă alergi des. Un sistem bun de amortizare reduce impactul asupra genunchilor și gleznelor. Fără el, alergarea pe bandă poate solicita articulațiile mai mult decât alergarea afară."
    },
    {
      "q": "Banda e zgomotoasă la bloc?",
      "a": "Depinde de motor și amortizare. Modelele cu motor inverter și platformă bine amortizată sunt mai silențioase. Un covor dedicat sub bandă reduce suplimentar zgomotul și vibrațiile transmise vecinilor."
    },
    {
      "q": "Merită conectivitatea cu aplicații?",
      "a": "Da, dacă te plictisești ușor. Aplicații ca Kinomap sau Zwift oferă trasee video și antrenamente ghidate care cresc motivația și consecvența. La modelele cu înclinare automată, aplicația poate ajusta singură panta."
    },
    {
      "q": "Se pliază pentru spațiu mic?",
      "a": "Majoritatea benzilor de casă se pliază pe verticală și au roți de transport. Verifică dimensiunile în stare pliată și greutatea totală — unele modele sunt grele de manevrat singur, chiar dacă se pliază."
    },
    {
      "q": "De ce viteză maximă am nevoie?",
      "a": "Pentru mers și jogging, 12 km/h ajunge. Pentru antrenamente de alergare mai intense, caută 16–18 km/h. Puțini folosesc viteza maximă în practică, dar o rezervă înseamnă un motor care lucrează mai relaxat."
    }
  ],
