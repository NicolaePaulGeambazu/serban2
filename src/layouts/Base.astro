---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CampaignStrip from '../components/CampaignStrip.astro';
import CookieConsent from '../components/CookieConsent.astro';
import Jsonld from '../components/Jsonld.astro';
import { site } from '../data/site';

interface Props {
  title?: string;
  description?: string;
  current?: string;
  ogImage?: string;
  noindex?: boolean;
  bodyClass?: string;
  showCampaign?: boolean;
}
const {
  title,
  description = site.description,
  current,
  ogImage,
  noindex = false,
  bodyClass,
  showCampaign = true,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? site.url).href;
const fullTitle = title ? `${title} — ${site.name}` : `${site.name} — ${site.tagline}`;
const ogImageUrl = ogImage ? new URL(ogImage, site.url).href : undefined;

const org = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: site.name,
  url: site.url,
  description: site.description,
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'customer support',
    url: `${site.url}/contact/`,
  },
};
const website = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: site.name,
  url: site.url,
  inLanguage: 'ro-RO',
};
---
<!doctype html>
<html lang={site.lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Google Consent Mode v2 — default denied until the visitor opts in -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('consent', 'default', {
        ad_storage: 'denied', ad_user_data: 'denied', ad_personalization: 'denied',
        analytics_storage: 'denied', functionality_storage: 'granted', security_storage: 'granted',
        wait_for_update: 500
      });
      // Returning visitors: apply their stored choice before any tag fires.
      try {
        var _c = JSON.parse(localStorage.getItem('vk_consent_v2') || 'null');
        if (_c) gtag('consent', 'update', {
          ad_storage: _c.marketing ? 'granted' : 'denied',
          ad_user_data: _c.marketing ? 'granted' : 'denied',
          ad_personalization: _c.marketing ? 'granted' : 'denied',
          analytics_storage: _c.analytics ? 'granted' : 'denied'
        });
      } catch (e) {}
    </script>
    <!-- Google Tag Manager -->
    <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-MJZLLCZC');</script>
    <!-- End Google Tag Manager -->
    <!-- Google tag (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-DXG9SNN3B4"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-DXG9SNN3B4');
    </script>
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    {site.googleSiteVerification && <meta name="google-site-verification" content={site.googleSiteVerification} />}
    {site.profitshareId && <meta name="profitshareid" content={site.profitshareId} />}
    <meta name="theme-color" content={site.themeColor} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="sitemap" href="/sitemap.xml" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={site.locale} />
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
    <meta name="twitter:card" content={ogImageUrl ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />

    <Jsonld schema={[org, website]} />
  </head>
  <body class={bodyClass}>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-MJZLLCZC"
      height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <a class="skip" href="#main">Sari la conținut</a>
    {showCampaign && <CampaignStrip />}
    <Header current={current} />
    <main id="main"><slot /></main>
    <Footer />
    <slot name="after" />
    <CookieConsent />
    <script>
      // ProfitShare automatic affiliate-link script (converts outbound links to
      // affiliate links at click-time). Loaded only after the visitor accepts
      // marketing cookies — mirrors the gclid logic below — but injected the moment
      // consent is granted (via the vk-consent event) so no reload is needed.
      (function () {
        var loaded = false;
        function hasMarketing() {
          try { var c = JSON.parse(localStorage.getItem('vk_consent_v2') || 'null'); return !!(c && c.marketing); } catch (e) { return false; }
        }
        function load() {
          if (loaded || !hasMarketing()) return;
          loaded = true;
          var bsa = document.createElement('script');
          bsa.type = 'text/javascript';
          bsa.async = true;
          bsa.src = '//l.profitshare.ro/files_shared/lps/js/0BC/xI.js?v=1784750891';
          (document.getElementsByTagName('head')[0] || document.getElementsByTagName('body')[0]).appendChild(bsa);
        }
        load();                                   // on load (if consent already given)
        window.addEventListener('vk-consent', load); // the moment the user accepts
      })();
    </script>
    <script>
      // Google Ads attribution: capture gclid and pass it into Profitshare links
      // (so a commission can be matched back to the ad click). Only when the visitor
      // has accepted marketing cookies.
      (function () {
        try {
          var p = new URLSearchParams(location.search);
          var gid = p.get('gclid') || p.get('gbraid') || p.get('wbraid');
          if (gid) localStorage.setItem('vk_gclid', gid);
          function hasMarketing() {
            try { var c = JSON.parse(localStorage.getItem('vk_consent_v2') || 'null'); return !!(c && c.marketing); } catch (e) { return false; }
          }
          function tag(a) {
            var g = localStorage.getItem('vk_gclid');
            var href = a.getAttribute('href');
            if (!g || !href || href.indexOf('psntrf=') > -1) return;
            a.setAttribute('href', href + (href.indexOf('?') > -1 ? '&' : '?') + 'psntrf=' + encodeURIComponent(g));
          }
          function run() {
            if (!localStorage.getItem('vk_gclid') || !hasMarketing()) return;
            document.querySelectorAll('a[href*="l.profitshare.ro/l/"]').forEach(tag);
          }
          run();                                   // on load (if consent already given)
          window.addEventListener('vk-consent', run); // re-run the moment the user accepts
          document.addEventListener('click', function (e) {  // fallback on click
            var a = e.target.closest && e.target.closest('a[href*="l.profitshare.ro/l/"]');
            if (a && hasMarketing()) tag(a);
          }, true);
        } catch (e) {}
      })();
    </script>
  </body>
</html>
