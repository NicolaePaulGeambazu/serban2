---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CampaignStrip from '../components/CampaignStrip.astro';
import CookieConsent from '../components/CookieConsent.astro';
import Jsonld from '../components/Jsonld.astro';
import { site } from '../data/site';

interface Props {
  title?: string;
  description?: string;
  current?: string;
  ogImage?: string;
  noindex?: boolean;
  bodyClass?: string;
  showCampaign?: boolean;
}
const {
  title,
  description = site.description,
  current,
  ogImage,
  noindex = false,
  bodyClass,
  showCampaign = true,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? site.url).href;
const fullTitle = title ? `${title} — ${site.name}` : `${site.name} — ${site.tagline}`;
const ogImageUrl = ogImage ? new URL(ogImage, site.url).href : undefined;

const org = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: site.name,
  url: site.url,
  description: site.description,
  email: site.email,
};
const website = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: site.name,
  url: site.url,
  inLanguage: 'ro-RO',
};
---
<!doctype html>
<html lang={site.lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    {site.googleSiteVerification && <meta name="google-site-verification" content={site.googleSiteVerification} />}
    <meta name="theme-color" content={site.themeColor} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="sitemap" href="/sitemap.xml" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={site.locale} />
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
    <meta name="twitter:card" content={ogImageUrl ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />

    <Jsonld schema={[org, website]} />
  </head>
  <body class={bodyClass}>
    <a class="skip" href="#main">Sari la conținut</a>
    {showCampaign && <CampaignStrip />}
    <Header current={current} />
    <main id="main"><slot /></main>
    <Footer />
    <slot name="after" />
    <CookieConsent />
    <script>
      // Google Ads attribution: capture gclid and pass it into Profitshare links
      // (so a commission can be matched back to the ad click). Only when the visitor
      // has accepted marketing cookies.
      (function () {
        try {
          var p = new URLSearchParams(location.search);
          var gid = p.get('gclid') || p.get('gbraid') || p.get('wbraid');
          if (gid) localStorage.setItem('vk_gclid', gid);
          var gclid = localStorage.getItem('vk_gclid');
          if (!gclid) return;
          var consent = null;
          try { consent = JSON.parse(localStorage.getItem('vk_consent_v2') || 'null'); } catch (e) {}
          if (!consent || !consent.marketing) return; // ad tracking needs marketing consent
          function tag(a) {
            var href = a.getAttribute('href');
            if (!href || href.indexOf('psntrf=') > -1) return;
            a.setAttribute('href', href + (href.indexOf('?') > -1 ? '&' : '?') + 'psntrf=' + encodeURIComponent(gclid));
          }
          // tag existing affiliate links on load (inspectable) + any clicked later
          document.querySelectorAll('a[href*="l.profitshare.ro/l/"]').forEach(tag);
          document.addEventListener('click', function (e) {
            var a = e.target.closest && e.target.closest('a[href*="l.profitshare.ro/l/"]');
            if (a) tag(a);
          }, true);
        } catch (e) {}
      })();
    </script>
  </body>
</html>
